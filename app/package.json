{
  "name": "work-time-expo",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "graphql:schema": "gql-tada generate-schema http://localhost:4000/graphql --output ./src/graphql/schema.graphql",
    "graphql:generate": "gql-tada generate-output",
    "graphql:sync": "npm run graphql:schema && npm run graphql:generate"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.4.1",
    "@sentry/react-native": "~6.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~52.0.49",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.22",
    "expo-status-bar": "~2.0.1",
    "expo-updates": "~0.27.5",
    "gql.tada": "^1.9.0",
    "graphql": "^16.13.1",
    "nativewind": "~4.1.23",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.11"
